{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug: Current HTML File",
      "type": "chrome",
      "request": "launch",
      "file": "${file}",
      "webRoot": "${workspaceFolder}"
    },
    {
      "name": "Debug: Current JS File",
      "type": "node",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "01 Basic For Loop",
      "type": "node",
      "request": "launch",
      "runtimeArgs": ["${workspaceFolder}/examples/01_basic_for_loop.js"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
